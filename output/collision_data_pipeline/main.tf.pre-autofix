# --- collision_processor ---
data "archive_file" "collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1_placeholder" {
  type        = "zip"
  output_path = "${path.module}/collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1_placeholder.zip"
  source {
    content  = "import json\nimport boto3\nimport os\n\ns3 = boto3.client('s3')\n\ndef handler(event, context):\n    # Get source bucket and key from S3 event\n    source_bucket = event['Records'][0]['s3']['bucket']['name']\n    source_key = event['Records'][0]['s3']['object']['key']\n    \n    # Get target bucket from environment\n    target_bucket = os.environ['STAGING_BUCKET']\n    \n    # Read raw data\n    response = s3.get_object(Bucket=source_bucket, Key=source_key)\n    raw_data = response['Body'].read().decode('utf-8')\n    \n    # Process collision data\n    lines = raw_data.strip().split('\\n')\n    processed_data = []\n    for line in lines:\n        # Basic transformation/validation\n        processed_data.append(line.strip())\n    \n    # Write to staging\n    target_key = f\"collision/{source_key.split('/')[-1]}\"\n    s3.put_object(\n        Bucket=target_bucket,\n        Key=target_key,\n        Body='\\n'.join(processed_data)\n    )\n    \n    return {'statusCode': 200, 'message': 'Collision data processed'}\n"
    filename = "index.py"
  }
}

resource "aws_iam_role" "collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1_role" {
  name = "collision-data-pipeline-azrd-ds-cc-1-lambda-collisi-e65227f-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "lambda.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = {
    Pipeline      = "collision_data_pipeline"
    BusinessUnit  = "azrd_ds"
    CostCenter    = "cc_1"
    ManagedBy     = "aws-pipeline-engine"
  }
}

resource "aws_iam_role_policy" "collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1_policy" {
  name = "collision-data-pipeline-azrd-ds-cc-1-lambda-colli-e65227f-policy"
  role = aws_iam_role.collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect   = "Allow"
      Action   = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "s3:GetObject",
          "s3:ListBucket",
          "s3:PutObject",
          "s3:DeleteObject"
      ]
      Resource = "*"
    }]
  })
}

