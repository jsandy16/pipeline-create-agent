resource "aws_s3_bucket_notification" "collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_notification" {
  bucket = aws_s3_bucket.collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1.id

  lambda_function {
    id                  = "collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1"
    filter_prefix       = "collision_raw/"
    lambda_function_arn = aws_lambda_function.collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1.arn
    events              = ["s3:ObjectCreated:*"]
  }
  lambda_function {
    id                  = "collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_collision_data_pipeline_azrd_ds_cc_1_lambda_party_processor_2"
    filter_prefix       = "party_raw/"
    lambda_function_arn = aws_lambda_function.collision_data_pipeline_azrd_ds_cc_1_lambda_party_processor_2.arn
    events              = ["s3:ObjectCreated:*"]
  }
  lambda_function {
    id                  = "collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_collision_data_pipeline_azrd_ds_cc_1_lambda_victim_processor_3"
    filter_prefix       = "victim_raw/"
    lambda_function_arn = aws_lambda_function.collision_data_pipeline_azrd_ds_cc_1_lambda_victim_processor_3.arn
    events              = ["s3:ObjectCreated:*"]
  }
  lambda_function {
    id                  = "collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_collision_data_pipeline_azrd_ds_cc_1_lambda_case_processor_4"
    filter_prefix       = "case_raw/"
    lambda_function_arn = aws_lambda_function.collision_data_pipeline_azrd_ds_cc_1_lambda_case_processor_4.arn
    events              = ["s3:ObjectCreated:*"]
  }
  depends_on = [aws_lambda_permission.collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_invoke_collision_data_pipeline_azrd_ds_cc_1_lambda_collision_processor_1, aws_lambda_permission.collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_invoke_collision_data_pipeline_azrd_ds_cc_1_lambda_party_processor_2, aws_lambda_permission.collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_invoke_collision_data_pipeline_azrd_ds_cc_1_lambda_victim_processor_3, aws_lambda_permission.collision_data_pipeline_azrd_ds_cc_1_s3_raw_data_bucket_1_invoke_collision_data_pipeline_azrd_ds_cc_1_lambda_case_processor_4]
}

