terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = "~> 2.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}


# --- collision_bucket ---
resource "aws_s3_bucket" "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1" {
  bucket        = "batch-data-processing-pipeline-engineering-cc001-s3-col-aac5eda"
  force_destroy = true

  tags = {
    Pipeline      = "batch_data_processing_pipeline"
    BusinessUnit  = "engineering"
    CostCenter    = "cc001"
    ManagedBy     = "aws-pipeline-engine"
  }
}

resource "aws_s3_bucket_versioning" "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_versioning" {
  bucket = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1.id

  versioning_configuration {
    status = "Suspended"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_sse" {
  bucket = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_lambda_permission" "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_invoke_batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1" {
  statement_id  = "AllowS3-batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1-batch_data_p-600bdd49"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1.function_name
  principal     = "s3.amazonaws.com"
  source_arn    = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1.arn
}

resource "aws_s3_bucket_notification" "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_notification" {
  bucket = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1.id

  lambda_function {
    id                  = "batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1"
    filter_prefix       = "collision_raw/"
    lambda_function_arn = aws_lambda_function.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1.arn
    events              = ["s3:ObjectCreated:*"]
  }
  depends_on = [aws_lambda_permission.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1_invoke_batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1]
