# --- collision_processor ---
data "archive_file" "batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_placeholder" {
  type        = "zip"
  output_path = "${path.module}/batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_placeholder.zip"
  source {
    content  = "import json\nimport os\nimport boto3\n\ndef handler(event, context):\n    s3_client = boto3.client('s3')\n    staging_bucket = os.environ.get('COLLISION_STAGING_BUCKET_NAME')\n    \n    for record in event['Records']:\n        bucket = record['s3']['bucket']['name']\n        key = record['s3']['object']['key']\n        print(f'Processing collision data: s3://{bucket}/{key}')\n        \n        # Read source data\n        response = s3_client.get_object(Bucket=bucket, Key=key)\n        data = response['Body'].read().decode('utf-8')\n        \n        # Process and write to staging\n        processed_key = key.replace('collision_raw/', 'collision_staging/')\n        s3_client.put_object(\n            Bucket=staging_bucket,\n            Key=processed_key,\n            Body=data\n        )\n    \n    return {'statusCode': 200, 'body': 'Collision data processed'}"
    filename = "index.py"
  }
}

resource "aws_iam_role" "batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_role" {
  name = "batch-data-processing-pipeline-engineering-cc001-la-5a21032-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "lambda.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = {
    Pipeline      = "batch_data_processing_pipeline"
    BusinessUnit  = "engineering"
    CostCenter    = "cc001"
    ManagedBy     = "aws-pipeline-engine"
  }
}

resource "aws_iam_role_policy" "batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_policy" {
  name = "batch-data-processing-pipeline-engineering-cc001-5a21032-policy"
  role = aws_iam_role.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect   = "Allow"
      Action   = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "s3:GetObject",
          "s3:ListBucket",
          "s3:PutObject",
          "s3:DeleteObject"
      ]
      Resource = "*"
    }]
  })
}

resource "aws_cloudwatch_log_group" "batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_lg" {
  name              = "/aws/lambda/batch-data-processing-pipeline-engineering-cc001-lambda-6a1a0a0"
  retention_in_days = 7

  tags = {
    Pipeline      = "batch_data_processing_pipeline"
    BusinessUnit  = "engineering"
    CostCenter    = "cc001"
    ManagedBy     = "aws-pipeline-engine"
  }
}

resource "aws_lambda_function" "batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1" {
  function_name    = "batch-data-processing-pipeline-engineering-cc001-lambda-6a1a0a0"
  role             = aws_iam_role.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_role.arn
  runtime          = "python3.12"
  handler          = "index.handler"
  memory_size      = 128
  timeout          = 300
  filename         = data.archive_file.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_placeholder.output_path
  source_code_hash = data.archive_file.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_placeholder.output_base64sha256

  environment {
    variables = {
      COLLISION_BUCKET_BUCKET = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_bucket_1.id
      COLLISION_STAGING_BUCKET_BUCKET = aws_s3_bucket.batch_data_processing_pipeline_engineering_cc001_s3_collision_staging_bucket_5.id
    }
  }

  tags = {
    Pipeline      = "batch_data_processing_pipeline"
    BusinessUnit  = "engineering"
    CostCenter    = "cc001"
    ManagedBy     = "aws-pipeline-engine"
  }

  depends_on = [aws_cloudwatch_log_group.batch_data_processing_pipeline_engineering_cc001_lambda_collision_processor_1_lg]
}

