            "output_size": 551,
            "source": [
              {
                "content": "import json\nimport os\nimport boto3\n\ndef handler(event, context):\n    s3_client = boto3.client('s3')\n    staging_bucket = os.environ.get('PARTY_STAGING_BUCKET_NAME')\n    \n    for record in event['Records']:\n        bucket = record['s3']['bucket']['name']\n        key = record['s3']['object']['key']\n        print(f'Processing party data: s3://{bucket}/{key}')\n        \n        # Read source data\n        response = s3_client.get_object(Bucket=bucket, Key=key)\n        data = response['Body'].read().decode('utf-8')\n        \n        # Process and write to staging\n        processed_key = key.replace('party_raw/', 'party_staging/')\n        s3_client.put_object(\n            Bucket=staging_bucket,\n            Key=processed_key,\n            Body=data\n        )\n    \n    return {'statusCode': 200, 'body': 'Party data processed'}",
                "filename": "index.py"
              }
