terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = "~> 2.0"
    }
    time = {
      source  = "hashicorp/time"
      version = "~> 0.9"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}


# --- raw_data_bucket ---
resource "aws_s3_bucket" "collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1" {
  bucket        = "collision-data-minilake-sjanalytics-cc001-s3-raw-data-bucket-1"
  force_destroy = true

  tags = {
    Pipeline      = "collision_data_minilake"
    BusinessUnit  = "SJANALYTICS"
    CostCenter    = "cc001"
    ManagedBy     = "aws-pipeline-engine"
  }
}

resource "aws_s3_bucket_versioning" "collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1_versioning" {
  bucket = aws_s3_bucket.collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1.id

  versioning_configuration {
    status = "Suspended"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1_sse" {
  bucket = aws_s3_bucket.collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_lambda_permission" "collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1_invoke_collision_data_minilake_sjanalytics_cc001_lambda_collision_processor_1" {
  statement_id  = "AllowS3-collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1-collision_data_minil-704c537c"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.collision_data_minilake_sjanalytics_cc001_lambda_collision_processor_1.function_name
  principal     = "s3.amazonaws.com"
  source_arn    = aws_s3_bucket.collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1.arn
}

resource "aws_lambda_permission" "collision_data_minilake_sjanalytics_cc001_s3_raw_data_bucket_1_invoke_collision_data_minilake_sjanalytics_cc001_lambda_party_processor_2" {
